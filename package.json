  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:e2e:smoke": "cypress run --browser electron --spec \"cypress/e2e/homepage_content.cy.js,cypress/e2e/navigation_footer_links.cy.js,cypress/e2e/responsive_accessibility_smoke.cy.js\"",
    "test:e2e:a11y": "cypress run --browser electron --spec \"cypress/e2e/a11y/**/*.cy.js\"",
