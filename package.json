    "swiper": "^12.1.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "axe-core": "^4.11.3",
    "cypress": "^15.13.1",
    "cypress-axe": "^1.7.0"
  }
}
