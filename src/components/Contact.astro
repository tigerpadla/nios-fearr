---
// Contact form - Web3Forms integration
---

<section id="contact" class="py-20 sm:py-28 bg-brand-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <span
        class="text-brand-magenta font-medium text-sm uppercase tracking-[0.12em]"
        >Contact Us</span
      >
      <h2 class="mt-3 text-3xl sm:text-4xl font-medium text-brand-purple tracking-tight" style="font-family: var(--font-display);">
        Let's Start a Conversation
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4 mx-auto"></div>
      <p class="mt-4 text-brand-body/75 text-lg">
        Ready to ignite your ambition? Get in touch and let's discuss how we can
        help.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-5 gap-12" data-animate>
      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <!-- Form Status Messages -->
        <div id="form-success" class="hidden mb-6 p-4 rounded-xl bg-green-50 border border-green-200">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-green-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-green-800 font-medium">Thank you! Your message has been sent successfully.</span>
          </div>
        </div>

        <div id="form-error" class="hidden mb-6 p-4 rounded-xl bg-red-50 border border-red-200">
          <div class="flex items-center">
            <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-red-800 font-medium">Sorry, there was an error sending your message. Please try again.</span>
          </div>
        </div>

        <form id="contact-form" class="space-y-6">
          <!-- Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="18f4653b-1dc6-4315-b306-d4aedd0d81b3" />

          <!-- Honeypot field (hidden anti-spam measure) -->
          <input
            type="text"
            name="botcheck"
            style="position: absolute; left: -9999px; top: -9999px;"
            tabindex="-1"
            autocomplete="nope"
            aria-hidden="true"
          />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Name *</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                maxlength="100"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="Your name"
                aria-describedby="name-error"
              />
              <div id="name-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Email *</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                maxlength="255"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="your@email.com"
                aria-describedby="email-error"
              />
              <div id="email-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
            </div>
          </div>

          <div>
            <label
              for="subject"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Subject</label
            >
            <input
              type="text"
              id="subject"
              name="subject"
              maxlength="200"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
              placeholder="How can we help?"
            />
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Message *</label
            >
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              minlength="10"
              maxlength="2000"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body resize-none"
              placeholder="Tell us about your project or enquiry..."
              aria-describedby="message-error"></textarea>
            <div id="message-error" class="mt-1 text-sm text-red-600 hidden" role="alert"></div>
            <div class="mt-1 text-sm text-gray-500" id="message-count">0 / 2000 characters</div>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="bg-brand-purple text-white px-8 py-3.5 rounded-full font-semibold hover:bg-brand-purple-light transition-colors text-lg w-full sm:w-auto cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center"
          >
            <span id="btn-text">Send Message</span>
            <svg id="loading-spinner" class="hidden animate-spin ml-2 w-5 h-5 text-white" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>
      </div>

      <!-- Contact Details -->
      <div class="lg:col-span-2">
        <div class="bg-brand-purple rounded-2xl p-8 text-white h-full">
          <h3 class="text-xl font-semibold mb-8">Get in Touch</h3>

          <div class="space-y-6">
            <!-- Office -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Meet Us</p>
                <p class="leading-relaxed">
                  Unit 15 Somerton Road,<br />
                  Ballinlough,<br />
                  Cork, Ireland<br />
                  <span class="text-white/70">T12 N2D0</span>
                </p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Phone</p>
                <a
                  href="tel:+353868799566"
                  class="hover:text-brand-magenta transition-colors"
                  >+353 086 879 9566</a
                >
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Email</p>
                <a
                  href="mailto:ckeane@niosfearr.ie"
                  class="hover:text-brand-magenta transition-colors"
                  >ckeane@niosfearr.ie</a
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const loadingSpinner = document.getElementById('loading-spinner');
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const messageTextarea = document.getElementById('message');
    const messageCount = document.getElementById('message-count');

    // Character count for message field
    messageTextarea.addEventListener('input', function() {
      const count = this.value.length;
      const maxLength = this.getAttribute('maxlength');
      messageCount.textContent = `${count} / ${maxLength} characters`;

      if (count > maxLength * 0.9) {
        messageCount.classList.add('text-red-500');
        messageCount.classList.remove('text-gray-500');
      } else {
        messageCount.classList.add('text-gray-500');
        messageCount.classList.remove('text-red-500');
      }
    });

    // Email validation
    function isValidEmail(email) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return emailRegex.test(email);
    }

    // Clear previous error states
    function clearErrors() {
      const errorElements = form.querySelectorAll('[role="alert"]');
      errorElements.forEach(el => {
        el.textContent = '';
        el.classList.add('hidden');
      });

      const inputs = form.querySelectorAll('input, textarea');
      inputs.forEach(input => {
        input.classList.remove('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
        input.classList.add('border-gray-200', 'focus:border-brand-magenta', 'focus:ring-brand-magenta/20');
      });

      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');
    }

    // Show field error
    function showFieldError(fieldName, message) {
      const field = form.querySelector(`[name="${fieldName}"]`);
      const errorElement = document.getElementById(`${fieldName}-error`);

      if (field && errorElement) {
        field.classList.remove('border-gray-200', 'focus:border-brand-magenta', 'focus:ring-brand-magenta/20');
        field.classList.add('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');

        errorElement.textContent = message;
        errorElement.classList.remove('hidden');
      }
    }

    // Validate form fields
    function validateForm(formData) {
      const errors = [];

      // Check honeypot field (anti-spam)
      if (formData.get('botcheck')) {
        errors.push({ field: 'honeypot', message: 'Spam detected' });
        return errors;
      }

      // Name validation
      const name = formData.get('name')?.trim();
      if (!name) {
        errors.push({ field: 'name', message: 'Name is required' });
      } else if (name.length < 2) {
        errors.push({ field: 'name', message: 'Name must be at least 2 characters' });
      } else if (name.length > 100) {
        errors.push({ field: 'name', message: 'Name must be less than 100 characters' });
      }

      // Email validation
      const email = formData.get('email')?.trim();
      if (!email) {
        errors.push({ field: 'email', message: 'Email is required' });
      } else if (!isValidEmail(email)) {
        errors.push({ field: 'email', message: 'Please enter a valid email address' });
      } else if (email.length > 255) {
        errors.push({ field: 'email', message: 'Email must be less than 255 characters' });
      }

      // Message validation
      const message = formData.get('message')?.trim();
      if (!message) {
        errors.push({ field: 'message', message: 'Message is required' });
      } else if (message.length < 10) {
        errors.push({ field: 'message', message: 'Message must be at least 10 characters' });
      } else if (message.length > 2000) {
        errors.push({ field: 'message', message: 'Message must be less than 2000 characters' });
      }

      // Subject validation (optional but has max length)
      const subject = formData.get('subject')?.trim();
      if (subject && subject.length > 200) {
        errors.push({ field: 'subject', message: 'Subject must be less than 200 characters' });
      }

      return errors;
    }

    // Set loading state
    function setLoadingState(isLoading) {
      submitBtn.disabled = isLoading;

      if (isLoading) {
        btnText.textContent = 'Sending...';
        loadingSpinner.classList.remove('hidden');
      } else {
        btnText.textContent = 'Send Message';
        loadingSpinner.classList.add('hidden');
      }
    }

    // Submit form to Web3Forms
    async function submitToWeb3Forms(formData) {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: formData
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const result = await response.json();

      if (!result.success) {
        throw new Error(result.message || 'Form submission failed');
      }

      return result;
    }

    // Handle form submission
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      clearErrors();
      setLoadingState(true);

      try {
        const formData = new FormData(form);

        // Validate form
        const validationErrors = validateForm(formData);

        if (validationErrors.length > 0) {
          validationErrors.forEach(error => {
            if (error.field !== 'honeypot') {
              showFieldError(error.field, error.message);
            }
          });
          setLoadingState(false);
          return;
        }

        // Submit to Web3Forms
        await submitToWeb3Forms(formData);

        // Show success message
        successMsg.classList.remove('hidden');
        form.reset();
        messageCount.textContent = '0 / 2000 characters';

        // Scroll to success message
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });

      } catch (error) {
        console.error('Form submission error:', error);
        errorMsg.querySelector('span').textContent = error.message || 'Sorry, there was an error sending your message. Please try again.';
        errorMsg.classList.remove('hidden');

        // Scroll to error message
        errorMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } finally {
        setLoadingState(false);
      }
    });

    // Real-time validation on field blur
    ['name', 'email', 'message'].forEach(fieldName => {
      const field = form.querySelector(`[name="${fieldName}"]`);
      if (field) {
        field.addEventListener('blur', function() {
          const formData = new FormData();
          formData.set(fieldName, this.value);

          if (fieldName === 'name') {
            const name = this.value.trim();
            if (name && (name.length < 2 || name.length > 100)) {
              showFieldError(fieldName, 'Name must be 2-100 characters');
            }
          } else if (fieldName === 'email') {
            const email = this.value.trim();
            if (email && (!isValidEmail(email) || email.length > 255)) {
              showFieldError(fieldName, 'Please enter a valid email address');
            }
          } else if (fieldName === 'message') {
            const message = this.value.trim();
            if (message && (message.length < 10 || message.length > 2000)) {
              showFieldError(fieldName, 'Message must be 10-2000 characters');
            }
          }
        });
      }
    });
  });

  // Debug config
  if (typeof window !== 'undefined') {
    window.contactFormConfig = { service: 'Web3Forms', status: 'Ready' };
  }
</script>
