---

---

<section id="contact" class="py-20 sm:py-28 bg-brand-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <span
        class="text-brand-magenta font-semibold text-sm uppercase tracking-wider"
        >Contact Us</span
      >
      <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-brand-purple">
        Let's Start a Conversation
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4 mx-auto"></div>
      <p class="mt-4 text-brand-body/70 text-lg">
        Ready to ignite your ambition? Get in touch and let's discuss how we can
        help.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-5 gap-12" data-animate>
      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-6"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Name</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="Your name"
              />
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="your@email.com"
              />
            </div>
          </div>

          <div>
            <label
              for="subject"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Subject</label
            >
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
              placeholder="How can we help?"
            />
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body resize-none"
              placeholder="Tell us about your project or enquiry..."></textarea>
          </div>

          <button
            type="submit"
            class="bg-brand-magenta text-white px-8 py-3.5 rounded-full font-semibold hover:bg-brand-magenta-hover transition-colors text-lg w-full sm:w-auto cursor-pointer"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Details -->
      <div class="lg:col-span-2">
        <div class="bg-brand-purple rounded-2xl p-8 text-white h-full">
          <h3 class="text-xl font-semibold mb-6">Get in Touch</h3>

          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60">Email</p>
                <a
                  href="mailto:info@niosfearr.ie"
                  class="hover:text-brand-magenta transition-colors"
                  >info@niosfearr.ie</a
                >
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60">Location</p>
                <p>Ireland</p>
              </div>
            </div>

            <!-- Web -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60">Website</p>
                <p>niosfearr.ie</p>
              </div>
            </div>
          </div>

          <!-- Tagline -->
          <div class="mt-10 pt-6 border-t border-white/10">
            <p class="text-white/40 text-sm italic">
              "Níos Fearr" — Irish for "Better"
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
