---

---

<section id="contact" class="py-20 sm:py-28 bg-brand-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <span
        class="text-brand-magenta font-semibold text-sm uppercase tracking-wider"
        >Contact Us</span
      >
      <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-brand-purple">
        Let's Start a Conversation
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4 mx-auto"></div>
      <p class="mt-4 text-brand-body/70 text-lg">
        Ready to ignite your ambition? Get in touch and let's discuss how we can
        help.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-5 gap-12" data-animate>
      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="space-y-6"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Name</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="Your name"
              />
            </div>
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-brand-purple mb-2"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
                placeholder="your@email.com"
              />
            </div>
          </div>

          <div>
            <label
              for="subject"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Subject</label
            >
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body"
              placeholder="How can we help?"
            />
          </div>

          <div>
            <label
              for="message"
              class="block text-sm font-medium text-brand-purple mb-2"
              >Message</label
            >
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-brand-grey focus:border-brand-magenta focus:ring-2 focus:ring-brand-magenta/20 outline-none transition-all text-brand-body resize-none"
              placeholder="Tell us about your project or enquiry..."></textarea>
          </div>

          <button
            type="submit"
            class="bg-brand-purple text-white px-8 py-3.5 rounded-full font-semibold hover:bg-brand-purple-light transition-colors text-lg w-full sm:w-auto cursor-pointer"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Contact Details -->
      <div class="lg:col-span-2">
        <div class="bg-brand-purple rounded-2xl p-8 text-white h-full">
          <h3 class="text-xl font-semibold mb-8">Get in Touch</h3>

          <div class="space-y-6">
            <!-- Office -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Meet Us</p>
                <p class="leading-relaxed">
                  Unit 15 Somerton Road,<br />
                  Ballinlough,<br />
                  Cork, Ireland<br />
                  <span class="text-white/70">T12 N2D0</span>
                </p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Phone</p>
                <a
                  href="tel:+353868799566"
                  class="hover:text-brand-magenta transition-colors"
                  >+353 086 879 9566</a
                >
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <svg
                class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path>
              </svg>
              <div>
                <p class="text-sm text-white/60 mb-1">Email</p>
                <a
                  href="mailto:ckeane@niosfearr.ie"
                  class="hover:text-brand-magenta transition-colors"
                  >ckeane@niosfearr.ie</a
                >
              </div>
            </div>
          </div>

          <!-- Tagline -->
          <div class="mt-8 pt-6 border-t border-white/10">
            <p class="text-white/40 text-sm italic">
              "Níos Fearr" — Irish for "Better"
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
