---
import { clients } from "../data/clients";
---

<section class="py-12 sm:py-16 bg-brand-grey overflow-hidden">
  <p
    class="text-center text-sm font-medium uppercase tracking-[0.12em] text-brand-purple/85 mb-8 sm:mb-10 px-4"
  >
    Our accomplished team has worked with some of the most respected organisations
  </p>

  <div class="relative">
    <!-- Gradient fade edges - narrower on mobile -->
    <div
      class="absolute left-0 top-0 bottom-0 w-12 sm:w-24 bg-gradient-to-r from-brand-grey to-transparent z-10"
    >
    </div>
    <div
      class="absolute right-0 top-0 bottom-0 w-12 sm:w-24 bg-gradient-to-l from-brand-grey to-transparent z-10"
    >
    </div>

    <!-- Marquee track - tighter spacing on mobile -->
    <div class="flex animate-marquee gap-8 sm:gap-16 items-center w-max">
      {
        clients.map((client) => (
          <div class="flex items-center justify-center px-3 sm:px-10 shrink-0 h-12 sm:h-16">
            <img
              src={client.logo}
              alt={client.name}
              class="h-8 sm:h-12 max-w-[120px] sm:max-w-[180px] w-auto object-contain opacity-70
                     transition-opacity duration-500 ease-out hover:opacity-100"
            />
          </div>
        ))
      }
      {/* Duplicate for seamless loop */}
      {
        clients.map((client) => (
          <div
            class="flex items-center justify-center px-3 sm:px-10 shrink-0 h-12 sm:h-16"
            aria-hidden="true"
          >
            <img
              src={client.logo}
              alt=""
              class="h-8 sm:h-12 max-w-[120px] sm:max-w-[180px] w-auto object-contain opacity-70
                     transition-opacity duration-500 ease-out hover:opacity-100"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
