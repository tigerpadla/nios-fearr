---
import { clients } from "../data/clients";
---

<section class="py-16 bg-brand-grey overflow-hidden">
  <p
    class="text-center text-sm font-medium uppercase tracking-wider text-brand-body/50 mb-10"
  >
    Trusted by leading organisations
  </p>

  <div class="relative">
    <!-- Gradient fade edges -->
    <div
      class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-brand-grey to-transparent z-10"
    >
    </div>
    <div
      class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-brand-grey to-transparent z-10"
    >
    </div>

    <!-- Marquee track -->
    <div class="flex animate-marquee gap-16 items-center w-max">
      {
        clients.map((client) => (
          <div class="flex items-center justify-center px-10 shrink-0 h-18">
            <img
              src={client.logo}
              alt={client.name}
              class="h-14 max-w-[180px] w-auto object-contain opacity-75
                     transition-opacity duration-500 ease-out hover:opacity-100"
            />
          </div>
        ))
      }
      {/* Duplicate for seamless loop */}
      {
        clients.map((client) => (
          <div
            class="flex items-center justify-center px-10 shrink-0 h-18"
            aria-hidden="true"
          >
            <img
              src={client.logo}
              alt=""
              class="h-14 max-w-[180px] w-auto object-contain opacity-75
                     transition-opacity duration-500 ease-out hover:opacity-100"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
