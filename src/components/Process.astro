---
import { processSteps } from "../data/process-steps";
---

<section id="process" class="py-20 sm:py-28 bg-brand-grey">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl" data-animate>
      <span
        class="text-brand-magenta font-semibold text-sm uppercase tracking-wider"
        >How We Work</span
      >
      <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-brand-purple">
        Our Engagement Process
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4"></div>
      <p class="mt-4 text-brand-body/70 text-lg leading-relaxed">
        Every engagement follows a structured approach — from initial consultation through to ongoing optimisation — ensuring clarity and measurable outcomes at each stage.
      </p>
    </div>

    <div class="mt-12 space-y-4" data-animate>
      {
        processSteps.map((step, i) => (
          <div
            data-accordion-item
            data-open={i === 0 ? "true" : "false"}
            class="rounded-2xl border border-gray-200 bg-white overflow-hidden transition-colors duration-300 data-[open=true]:border-brand-magenta/30"
          >
            {/* Trigger */}
            <button
              data-accordion-trigger
              class="w-full flex items-center gap-4 sm:gap-6 p-5 sm:p-6 text-left cursor-pointer"
            >
              <span class="text-2xl sm:text-3xl font-bold text-brand-magenta/30 data-[open=true]:text-brand-magenta transition-colors shrink-0">
                {step.number}
              </span>
              <span class="text-lg sm:text-xl font-semibold text-brand-purple flex-1">
                {step.title}
              </span>
              {/* Plus/minus icon */}
              <span class="relative w-6 h-6 shrink-0">
                <span class="absolute top-1/2 left-0 w-6 h-0.5 bg-brand-purple rounded-full -translate-y-1/2 transition-transform" />
                <span class="absolute top-1/2 left-0 w-6 h-0.5 bg-brand-purple rounded-full -translate-y-1/2 transition-transform rotate-90 data-[open=true]:rotate-0" />
              </span>
            </button>

            {/* Collapsible content */}
            <div data-accordion-content>
              <div>
                <div class="px-5 sm:px-6 pb-6 pl-16 sm:pl-20">
                  <p class="text-brand-body/70 leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  function initAccordion() {
    const items = document.querySelectorAll("[data-accordion-item]");
    items.forEach((item) => {
      const trigger = item.querySelector("[data-accordion-trigger]");
      trigger?.addEventListener("click", () => {
        const isOpen = item.getAttribute("data-open") === "true";
        // Close all
        items.forEach((i) => i.setAttribute("data-open", "false"));
        // Toggle current
        if (!isOpen) {
          item.setAttribute("data-open", "true");
        }
      });
    });
  }
  document.addEventListener("astro:page-load", initAccordion);
</script>
