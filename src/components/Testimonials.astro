---
import { testimonials } from "../data/testimonials";
---

<section id="testimonials" class="py-16 sm:py-28 bg-brand-purple overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10 sm:mb-16" data-animate>
      <span
        class="text-brand-magenta font-medium text-sm uppercase tracking-[0.12em]"
        >Testimonials</span
      >
      <h2 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-semibold text-white tracking-tight" style="font-family: var(--font-display);">
        What Our Clients Say
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4 mx-auto"></div>
    </div>
  </div>

  <div class="relative">
    <!-- Gradient fade edges - hidden on mobile, subtle on desktop -->
    <div
      class="testimonial-fade-left absolute left-0 top-0 bottom-0 hidden sm:block sm:w-12 lg:w-16 z-10 pointer-events-none"
    >
    </div>
    <div
      class="testimonial-fade-right absolute right-0 top-0 bottom-0 hidden sm:block sm:w-12 lg:w-16 z-10 pointer-events-none"
    >
    </div>

    <!-- Marquee track -->
    <div class="testimonials-marquee flex gap-4 sm:gap-6 items-stretch w-max px-4 sm:px-0">
      {
        testimonials.map((t) => (
          <div class="testimonial-card bg-white rounded-2xl p-6 sm:p-8 shadow-lg border border-white/20 flex flex-col w-[calc(100vw-32px)] sm:w-[380px] lg:w-[420px] shrink-0">
            {/* Quote mark */}
            <svg
              class="w-8 h-8 sm:w-10 sm:h-10 text-brand-magenta/20 mb-3 sm:mb-4 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z" />
            </svg>

            {/* Quote text */}
            <blockquote class="text-brand-body/80 leading-[1.75] italic flex-1 text-base sm:text-lg font-light tracking-wide">
              "{t.quote}"
            </blockquote>

            {/* Attribution - pinned to bottom */}
            <div class="mt-auto pt-4 sm:pt-6 border-t border-gray-100">
              <p class="font-semibold text-brand-purple text-sm sm:text-base">{t.role}</p>
              <p class="text-xs sm:text-sm text-brand-body/70 mt-0.5 sm:mt-1">{t.company}</p>
              <p class="text-xs sm:text-sm text-brand-magenta-hover mt-0.5">
                {t.location}
              </p>
            </div>
          </div>
        ))
      }
      {/* Duplicate for seamless loop */}
      {
        testimonials.map((t) => (
          <div class="testimonial-card bg-white rounded-2xl p-6 sm:p-8 shadow-lg border border-white/20 flex flex-col w-[calc(100vw-32px)] sm:w-[380px] lg:w-[420px] shrink-0" aria-hidden="true">
            {/* Quote mark */}
            <svg
              class="w-8 h-8 sm:w-10 sm:h-10 text-brand-magenta/20 mb-3 sm:mb-4 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z" />
            </svg>

            {/* Quote text */}
            <blockquote class="text-brand-body/80 leading-[1.75] italic flex-1 text-base sm:text-lg font-light tracking-wide">
              "{t.quote}"
            </blockquote>

            {/* Attribution - pinned to bottom */}
            <div class="mt-auto pt-4 sm:pt-6 border-t border-gray-100">
              <p class="font-semibold text-brand-purple text-sm sm:text-base">{t.role}</p>
              <p class="text-xs sm:text-sm text-brand-body/70 mt-0.5 sm:mt-1">{t.company}</p>
              <p class="text-xs sm:text-sm text-brand-magenta-hover mt-0.5">
                {t.location}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Soft gradient fades - tablet and desktop only */
  .testimonial-fade-left {
    background: linear-gradient(
      to right,
      var(--color-brand-purple) 0%,
      rgba(80, 67, 155, 0.5) 40%,
      rgba(80, 67, 155, 0) 100%
    );
  }

  .testimonial-fade-right {
    background: linear-gradient(
      to left,
      var(--color-brand-purple) 0%,
      rgba(80, 67, 155, 0.5) 40%,
      rgba(80, 67, 155, 0) 100%
    );
  }

  /* Continuous marquee animation */
  .testimonials-marquee {
    animation: marquee 80s linear infinite;
    cursor: grab;
    user-select: none;
    will-change: transform;
    -webkit-user-select: none;
    -webkit-touch-callout: none;
  }

  .testimonials-marquee.is-dragging {
    animation: none !important;
    cursor: grabbing;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Card styling - subtle hover effect, no lift */
  .testimonial-card {
    transition: box-shadow 0.3s ease;
  }

  @media (min-width: 640px) {
    .testimonials-marquee:not(.is-dragging) .testimonial-card:hover {
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
  }

  /* Disable all card effects while dragging */
  .testimonials-marquee.is-dragging .testimonial-card {
    transition: none !important;
    transform: none !important;
    pointer-events: none;
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .testimonials-marquee {
      animation: none;
    }
  }
</style>

<script>
  function initTestimonialsMarquee() {
    const marquee = document.querySelector('.testimonials-marquee') as HTMLElement;
    if (!marquee) return;

    let isDragging = false;
    let startX = 0;
    let dragStartX = 0;
    let totalWidth = 0;

    // Calculate total width once
    function calculateTotalWidth(): number {
      return marquee.scrollWidth / 2;
    }

    // Get current X position from computed transform
    function getCurrentX(): number {
      const style = window.getComputedStyle(marquee);
      const transform = style.transform;
      if (transform === 'none') return 0;
      const matrix = new DOMMatrix(transform);
      return matrix.m41;
    }

    // Start drag
    function handleDragStart(e: MouseEvent | TouchEvent) {
      if (isDragging) return;

      totalWidth = calculateTotalWidth();

      // Get current position immediately
      const currentX = getCurrentX();

      // Set transform BEFORE adding class to prevent jump
      marquee.style.transform = `translateX(${currentX}px)`;

      // Force browser to apply the style synchronously
      marquee.offsetHeight;

      // Now safe to stop animation
      marquee.classList.add('is-dragging');
      isDragging = true;

      // Store starting positions
      startX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      dragStartX = currentX;
    }

    // During drag
    function handleDragMove(e: MouseEvent | TouchEvent) {
      if (!isDragging) return;
      e.preventDefault();

      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const deltaX = clientX - startX;
      let newX = dragStartX + deltaX;

      // Wrap around for infinite feel
      while (newX > 0) {
        newX -= totalWidth;
      }
      while (newX < -totalWidth) {
        newX += totalWidth;
      }

      marquee.style.transform = `translateX(${newX}px)`;
    }

    // End drag
    function handleDragEnd() {
      if (!isDragging) return;

      // Get final position
      const finalX = getCurrentX();

      // Normalize to valid range
      let normalizedX = finalX % totalWidth;
      if (normalizedX > 0) normalizedX -= totalWidth;

      // Calculate animation progress (0 to 1)
      const progress = Math.abs(normalizedX) / totalWidth;

      // Set the animation delay to resume from current position
      marquee.style.animationDelay = `-${progress * 80}s`;

      // Clear inline transform and restart animation
      marquee.style.transform = '';

      // Force reflow before removing class
      marquee.offsetHeight;

      marquee.classList.remove('is-dragging');
      isDragging = false;
    }

    // Mouse events
    marquee.addEventListener('mousedown', handleDragStart);
    document.addEventListener('mousemove', handleDragMove, { passive: false });
    document.addEventListener('mouseup', handleDragEnd);

    // Touch events
    marquee.addEventListener('touchstart', handleDragStart, { passive: false });
    document.addEventListener('touchmove', handleDragMove, { passive: false });
    document.addEventListener('touchend', handleDragEnd);
    document.addEventListener('touchcancel', handleDragEnd);

    // Prevent native drag
    marquee.addEventListener('dragstart', (e) => e.preventDefault());

    // Prevent context menu on long press
    marquee.addEventListener('contextmenu', (e) => {
      if (isDragging) e.preventDefault();
    });
  }

  document.addEventListener('astro:page-load', initTestimonialsMarquee);
</script>