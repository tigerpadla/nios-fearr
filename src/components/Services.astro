---

<section id="services" class="py-20 sm:py-28 bg-brand-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {
      serviceCategories.map((category, catIdx) => (
        <div class:list={[catIdx > 0 && "mt-24"]} data-animate>
          {/* Section header */}
          <div class="max-w-2xl">
            <span class="text-brand-magenta font-medium text-sm uppercase tracking-[0.12em]">
              {category.subtitle}
            </span>
            <h2 class="mt-3 text-3xl sm:text-4xl font-semibold text-brand-purple tracking-tight" style="font-family: var(--font-display);">
              {category.title}
            </h2>
            <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4" />
            <p class="mt-4 text-brand-body/75 text-lg leading-relaxed">
              {category.description}
            </p>
          </div>

          {/* Service cards grid */}
          <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {category.services.map((service, i) => (
              <div
                data-animate
                style={`transition-delay: ${i * 80}ms`}
                class:list={[
                  "group rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg border",
                  i % 2 === 0
                    ? "bg-brand-grey border-transparent"
                    : "bg-white border-gray-100",
                ]}
              >
                {/* Icon */}
                <div class="w-12 h-12 rounded-xl bg-brand-purple/10 flex items-center justify-center mb-4 group-hover:bg-brand-magenta/10 transition-colors">
                  <svg
                    class="w-6 h-6 text-brand-purple group-hover:text-brand-magenta transition-colors"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={iconMap[service.icon] || iconMap.transform} />
                  </svg>
                </div>

                <h3 class="text-lg font-semibold text-brand-purple">
                  {service.title}
                </h3>
                <p class="mt-2 text-sm text-brand-body/60 leading-relaxed">
                  {service.description}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
