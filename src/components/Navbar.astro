---
const navLinks = [
  { label: "Services", href: "/#services" },
  { label: "Mentoring", href: "/#mentoring" },
  { label: "Approach", href: "/#process" },
  { label: "Why Us", href: "/#why-us" },
  { label: "Testimonials", href: "/#testimonials" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4"
>
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between"
  >
    <!-- Logo: white over hero, purple after scroll -->
    <a href="/" class="flex items-center shrink-0">
      <img
        id="logo-white"
        src="/images/brand/nios-fearr-logo-white.png"
        alt="Níos Fearr Consulting"
        class="h-10 sm:h-12 w-auto drop-shadow-[0_1px_2px_rgba(0,0,0,0.3)] transition-opacity duration-300"
      />
      <img
        id="logo-purple"
        src="/images/brand/nios-fearr-logo-purple.png"
        alt="Níos Fearr Consulting"
        class="h-10 sm:h-12 w-auto hidden transition-opacity duration-300"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-white/90 hover:text-brand-magenta transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        id="nav-cta"
        href="/#contact"
        class="bg-brand-magenta text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-brand-magenta-hover transition-all duration-300"
      >
        Get in Touch
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-white p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        id="hamburger-icon"
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-brand-purple/95 backdrop-blur-md mt-2"
  >
    <div class="px-4 py-4 flex flex-col gap-3">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-white/90 hover:text-brand-magenta transition-colors py-2 text-lg"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/#contact"
        class="mobile-nav-link bg-brand-magenta text-white px-5 py-2.5 rounded-full text-center font-semibold hover:bg-brand-magenta-hover transition-colors mt-2"
      >
        Get in Touch
      </a>
    </div>
  </div>
</nav>

<script>
  function initNavbar() {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const hamburger = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");
    const logoWhite = document.getElementById("logo-white");
    const logoPurple = document.getElementById("logo-purple");
    const navCta = document.getElementById("nav-cta");
    const hasHero = !!document.querySelector("section.bg-brand-purple");

    // Frosted glass on scroll
    function updateNavbar() {
      if (!navbar) return;
      if (window.scrollY > 60 || !hasHero) {
        navbar.classList.add(
          "bg-white/90",
          "backdrop-blur-md",
          "shadow-sm",
          "py-2",
        );
        navbar.classList.remove("py-4");
        // Swap to purple logo
        logoWhite?.classList.add("hidden");
        logoPurple?.classList.remove("hidden");
        // Nav link colors
        navbar
          .querySelectorAll(".nav-link")
          .forEach((a) => {
            a.classList.remove("text-white/90", "text-white", "text-white/70", "hover:text-brand-magenta");
            a.classList.add("text-brand-body", "hover:text-brand-purple");
          });
        btn?.classList.remove("text-white");
        btn?.classList.add("text-brand-body");
        // CTA: pink → purple
        navCta?.classList.remove("bg-brand-magenta", "hover:bg-brand-magenta-hover");
        navCta?.classList.add("bg-brand-purple", "hover:bg-brand-purple-light");
      } else {
        navbar.classList.remove(
          "bg-white/90",
          "backdrop-blur-md",
          "shadow-sm",
          "py-2",
        );
        navbar.classList.add("py-4");
        // Swap to white logo
        logoWhite?.classList.remove("hidden");
        logoPurple?.classList.add("hidden");
        // Nav link colors
        navbar
          .querySelectorAll(".nav-link")
          .forEach((a) => {
            a.classList.remove("text-brand-body", "hover:text-brand-purple");
            a.classList.add("text-white/90", "hover:text-brand-magenta");
          });
        btn?.classList.remove("text-brand-body");
        btn?.classList.add("text-white");
        // CTA: purple → pink
        navCta?.classList.remove("bg-brand-purple", "hover:bg-brand-purple-light");
        navCta?.classList.add("bg-brand-magenta", "hover:bg-brand-magenta-hover");
      }
    }

    window.addEventListener("scroll", updateNavbar, { passive: true });
    updateNavbar();

    // Mobile menu toggle
    btn?.addEventListener("click", () => {
      const isOpen = menu?.classList.contains("hidden") === false;
      menu?.classList.toggle("hidden");
      hamburger?.classList.toggle("hidden");
      closeIcon?.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));
    });

    // Close mobile menu on anchor click
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu?.classList.add("hidden");
        hamburger?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
        btn?.setAttribute("aria-expanded", "false");
      });
    });
  }

  document.addEventListener("astro:page-load", initNavbar);
</script>
