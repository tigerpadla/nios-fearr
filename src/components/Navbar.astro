---
const navLinks = [
  { label: "Services", href: "/#services" },
  { label: "Mentoring", href: "/#mentoring" },
  { label: "Approach", href: "/#process" },
  { label: "Why Us", href: "/#why-us" },
  { label: "Testimonials", href: "/#testimonials" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4"
>
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex items-center justify-between"
  >
    <!-- Logo: white over hero, purple after scroll -->
    <a href="/" class="flex items-center shrink-0 relative z-[60]">
      <img
        id="logo-white"
        src="/images/brand/nios-fearr-logo-white.png"
        alt="Níos Fearr Consulting"
        class="h-10 sm:h-12 w-auto drop-shadow-[0_1px_2px_rgba(0,0,0,0.3)] transition-opacity duration-300"
      />
      <img
        id="logo-purple"
        src="/images/brand/nios-fearr-logo-purple.png"
        alt="Níos Fearr Consulting"
        class="h-10 sm:h-12 w-auto hidden transition-opacity duration-300"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-white/90 hover:text-brand-magenta transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        id="nav-cta"
        href="/#contact"
        class="bg-brand-magenta-hover text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-brand-magenta-hover transition-all duration-300"
      >
        Get in Touch
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-white p-2 relative z-[60] transition-colors duration-300"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        id="hamburger-icon"
        class="w-6 h-6 transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu: slide-in panel -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[55] md:hidden"
  aria-hidden="true"
  style="pointer-events: none;"
>
  <!-- Backdrop -->
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-black/40 z-10"
    style="opacity: 0; transition: none;"
  ></div>

  <!-- Panel -->
  <div
    id="mobile-menu-panel"
    class="mobile-panel absolute top-0 right-0 bottom-0 w-[85%] max-w-[320px] bg-brand-purple z-20"
    style="pointer-events: auto; transform: translateX(100%); transition: none; box-shadow: -8px 0 24px rgba(0, 0, 0, 0.2), inset 1px 0 0 rgba(255, 255, 255, 0.05);"
  >
    <!-- Close button -->
    <div class="flex justify-end p-4">
      <button
        id="mobile-menu-close"
        class="text-white/70 hover:text-white p-2 transition-colors hover:bg-white/5 rounded-lg"
        aria-label="Close menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Decorative accent -->
    <div class="menu-accent absolute top-20 left-6 w-12 h-[2px] bg-gradient-to-r from-brand-magenta to-transparent opacity-0" aria-hidden="true"></div>

    <!-- Background geometry (borrowed from hero) -->
    <div class="absolute -top-6 -left-6 w-32 h-32 bg-white/[0.015] rounded-xl rotate-12 menu-geometry-block opacity-0" aria-hidden="true"></div>

    <svg
      class="absolute bottom-2 -left-6 w-28 h-28 rotate-[25deg] menu-geometry-triangle opacity-0"
      viewBox="0 0 100 100"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M50 10 L90 80 L10 80 Z"
        stroke="rgba(233, 30, 123, 0.12)"
        stroke-width="1.5"
        fill="none"
      />
    </svg>

    <svg
      class="absolute top-[35%] -right-4 w-24 h-24 -rotate-[30deg] menu-geometry-triangle-right opacity-0"
      viewBox="0 0 100 100"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M50 10 L90 80 L10 80 Z"
        stroke="rgba(233, 30, 123, 0.12)"
        stroke-width="1.5"
        fill="none"
      />
    </svg>

    <!-- Brand watermark -->
    <div class="absolute bottom-32 -right-12 w-64 opacity-0 pointer-events-none menu-watermark" aria-hidden="true">
      <img
        src="/images/brand/nios-fearr-logo-mark-purple.png"
        alt=""
        class="w-full h-auto brightness-0 invert opacity-[0.04]"
      />
    </div>

    <!-- Menu content -->
    <div class="flex flex-col h-[calc(100%-64px)] px-6 pb-8">
      <!-- Nav links -->
      <nav class="flex-1 pt-4">
        <ul class="space-y-1">
          {
            navLinks.map((link, i) => (
              <li class="menu-nav-item" style={`transition-delay: ${i * 40}ms`}>
                <a
                  href={link.href}
                  class="mobile-nav-link group block py-3.5 text-lg font-medium text-white/90 transition-colors relative"
                >
                  <span class="relative z-10">{link.label}</span>
                  <span class="absolute left-0 bottom-2 w-0 h-[2px] bg-brand-magenta group-hover:w-8 transition-all duration-300 ease-out"></span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- CTA -->
      <div class="menu-cta pt-6 border-t border-white/10">
        <a
          href="/#contact"
          class="mobile-nav-link group flex items-center justify-between bg-brand-magenta text-white w-full px-5 py-4 rounded-xl font-semibold transition-all duration-200 hover:bg-brand-magenta-hover hover:shadow-lg active:scale-[0.98]"
        >
          <span>Get in Touch</span>
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Menu animations */
  .menu-nav-item {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  }

  .menu-cta {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease-out 0.25s, transform 0.3s ease-out 0.25s;
  }

  .menu-accent {
    transition: opacity 0.4s ease-out 0.15s, width 0.5s ease-out 0.15s;
  }

  .menu-geometry-block {
    transition: opacity 0.5s ease-out 0.2s;
  }

  .menu-geometry-triangle {
    transition: opacity 0.5s ease-out 0.25s;
  }

  .menu-geometry-triangle-right {
    transition: opacity 0.5s ease-out 0.3s;
  }

  .menu-watermark {
    transition: opacity 0.6s ease-out 0.3s;
  }

  /* Menu open state - trigger animations */
  #mobile-menu.menu-open .menu-nav-item {
    opacity: 1;
    transform: translateX(0);
  }

  #mobile-menu.menu-open .menu-cta {
    opacity: 1;
    transform: translateY(0);
  }

  #mobile-menu.menu-open .menu-accent {
    opacity: 0.6;
    width: 48px;
  }

  #mobile-menu.menu-open .menu-geometry-block {
    opacity: 1;
  }

  #mobile-menu.menu-open .menu-geometry-triangle {
    opacity: 1;
  }

  #mobile-menu.menu-open .menu-geometry-triangle-right {
    opacity: 1;
  }

  #mobile-menu.menu-open .menu-watermark {
    opacity: 1;
  }

  /* Prevent body scroll when menu is open */
  :global(body.mobile-menu-open) {
    overflow: hidden;
  }
</style>

<script>
  function initNavbar() {
    const navbar = document.getElementById("navbar");
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const panel = document.getElementById("mobile-menu-panel");
    const backdrop = document.getElementById("mobile-menu-backdrop");
    const closeBtn = document.getElementById("mobile-menu-close");
    const logoWhite = document.getElementById("logo-white");
    const logoPurple = document.getElementById("logo-purple");
    const navCta = document.getElementById("nav-cta");
    const hasHero = !!document.querySelector("section.bg-brand-purple");

    let isMenuOpen = false;

    // Ensure menu is closed on init and enable transitions
    if (menu && panel && backdrop) {
      menu.style.pointerEvents = "none";
      panel.style.transform = "translateX(100%)";
      backdrop.style.opacity = "0";
      menu.setAttribute("aria-hidden", "true");

      // Enable transitions after a brief delay to prevent initial animation
      requestAnimationFrame(() => {
        setTimeout(() => {
          panel.style.transition = "transform 300ms ease-out";
          backdrop.style.transition = "opacity 300ms";
        }, 50);
      });
    }

    // Frosted glass on scroll
    function updateNavbar() {
      if (!navbar) return;

      if (window.scrollY > 60 || !hasHero) {
        navbar.classList.add(
          "bg-white/90",
          "backdrop-blur-md",
          "shadow-sm",
          "py-2",
        );
        navbar.classList.remove("py-4");
        // Swap to purple logo
        logoWhite?.classList.add("hidden");
        logoPurple?.classList.remove("hidden");
        // Nav link colors
        navbar
          .querySelectorAll(".nav-link")
          .forEach((a) => {
            a.classList.remove("text-white/90", "text-white", "text-white/70", "hover:text-brand-magenta");
            a.classList.add("text-brand-body", "hover:text-brand-purple");
          });
        btn?.classList.remove("text-white");
        btn?.classList.add("text-brand-body");
        // CTA: pink → purple
        navCta?.classList.remove("bg-brand-magenta", "hover:bg-brand-magenta-hover");
        navCta?.classList.add("bg-brand-purple", "hover:bg-brand-purple-light");
      } else {
        navbar.classList.remove(
          "bg-white/90",
          "backdrop-blur-md",
          "shadow-sm",
          "py-2",
        );
        navbar.classList.add("py-4");
        // Swap to white logo
        logoWhite?.classList.remove("hidden");
        logoPurple?.classList.add("hidden");
        // Nav link colors
        navbar
          .querySelectorAll(".nav-link")
          .forEach((a) => {
            a.classList.remove("text-brand-body", "hover:text-brand-purple");
            a.classList.add("text-white/90", "hover:text-brand-magenta");
          });
        btn?.classList.remove("text-brand-body");
        btn?.classList.add("text-white");
        // CTA: purple → pink
        navCta?.classList.remove("bg-brand-purple", "hover:bg-brand-purple-light");
        navCta?.classList.add("bg-brand-magenta", "hover:bg-brand-magenta-hover");
      }
    }

    window.addEventListener("scroll", updateNavbar, { passive: true });
    updateNavbar();

    // Open mobile menu
    function openMenu() {
      if (!menu || !panel || !backdrop) return;

      isMenuOpen = true;
      menu.style.pointerEvents = "auto";
      panel.style.transform = "translateX(0)";
      backdrop.style.opacity = "1";
      menu.setAttribute("aria-hidden", "false");
      btn?.setAttribute("aria-expanded", "true");
      document.body.classList.add("mobile-menu-open");

      // Trigger animations
      requestAnimationFrame(() => {
        menu?.classList.add("menu-open");
      });
    }

    // Close mobile menu
    function closeMenu() {
      if (!menu || !panel || !backdrop) return;

      isMenuOpen = false;
      menu.style.pointerEvents = "none";
      panel.style.transform = "translateX(100%)";
      backdrop.style.opacity = "0";
      menu.setAttribute("aria-hidden", "true");
      btn?.setAttribute("aria-expanded", "false");
      document.body.classList.remove("mobile-menu-open");

      // Remove animation class
      menu?.classList.remove("menu-open");
    }

    // Toggle menu
    btn?.addEventListener("click", () => {
      if (isMenuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close button
    closeBtn?.addEventListener("click", closeMenu);

    // Close on backdrop click
    backdrop?.addEventListener("click", closeMenu);

    // Close on nav link click
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) {
        closeMenu();
      }
    });
  }

  document.addEventListener("astro:page-load", initNavbar);
</script>
