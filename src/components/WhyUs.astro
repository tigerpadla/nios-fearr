---
const differentiators = [
  {
    title: "Over 20 Years of Proven Experience",
    description:
      "Since 2004, we've delivered technology consultancy and mentoring across diverse industries and geographies. Our depth of experience means we've seen — and solved — the challenges your organisation faces.",
    points: [
      "Engagements across financial services, healthcare, pharma, government, and more",
      "International delivery experience from Dublin to New York to Basel",
      "Battle-tested approaches refined through hundreds of projects",
    ],
    illustration: "/images/brand/team-spirit-rafiki.svg",
  },
  {
    title: "Tailored Solutions, Not Templates",
    description:
      "We don't believe in one-size-fits-all. Every engagement begins with understanding your unique context, challenges, and objectives before crafting a bespoke approach.",
    points: [
      "Deep-dive discovery before any recommendations",
      "Strategies aligned to your business goals, not technology trends",
      "Flexible engagement models that adapt as your needs evolve",
    ],
    illustration: "/images/brand/business-plan-amico.svg",
  },
  {
    title: "Long-Term Partnerships",
    description:
      "Our clients don't just return — they refer us. We build enduring relationships founded on trust, transparency, and consistent delivery that extends far beyond the initial engagement.",
    points: [
      "Clients spanning 5, 10, and 15+ year relationships",
      "Repeat work built on trust and demonstrated results",
      "Acting as an extension of your team, not an outside vendor",
    ],
    illustration: "/images/brand/partnership-amico.svg",
  },
  {
    title: "Trusted Advisors Across Industries",
    description:
      "From global financial institutions to government departments, from biotech to construction — we bring cross-industry insight that enriches every engagement.",
    points: [
      "Worked with organisations from startups to multinationals",
      "Government, private sector, and non-profit experience",
      "Cross-pollination of best practices across industries",
    ],
    illustration: "/images/brand/meeting-rafiki.svg",
  },
];
---

<section id="why-us" class="py-20 sm:py-28 bg-brand-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <span
        class="text-brand-magenta font-semibold text-sm uppercase tracking-wider"
        >Why Choose Us</span
      >
      <h2 class="mt-2 text-3xl sm:text-4xl font-bold text-brand-purple">
        Built on Trust, Driven by Results
      </h2>
      <div class="w-16 h-1 bg-brand-magenta rounded-full mt-4 mx-auto"></div>
    </div>

    <div class="mt-16 space-y-20">
      {
        differentiators.map((item, i) => (
          <div
            data-animate
            class:list={[
              "flex flex-col gap-8 items-center",
              "md:flex-row",
              i % 2 !== 0 && "md:flex-row-reverse",
            ]}
          >
            {/* Visual — Illustrations for all items */}
            <div class="flex-1 flex justify-center">
              <div class="w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96 flex items-center justify-center">
                <img
                  src={item.illustration}
                  alt={item.title}
                  class="w-full h-full object-contain"
                />
              </div>
            </div>

            {/* Content */}
            <div class="flex-1">
              <h3 class="text-2xl font-bold text-brand-purple">{item.title}</h3>
              <p class="mt-3 text-brand-body/70 leading-relaxed">
                {item.description}
              </p>
              <ul class="mt-5 space-y-3">
                {item.points.map((point) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="w-5 h-5 text-brand-magenta shrink-0 mt-0.5"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    <span class="text-sm text-brand-body/60">{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
