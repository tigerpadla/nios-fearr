---

---

<section
  class="relative min-h-screen flex items-center bg-brand-purple overflow-hidden"
>
  <!-- Background layers -->
  <div class="absolute inset-0" aria-hidden="true">
    <!-- Soft radial glow — shifts lower-right on mobile, centred-right on desktop -->
    <div
      class="hero-glow absolute top-[65%] right-[5%] sm:top-1/2 sm:right-[10%] -translate-y-1/2
             w-[280px] h-[280px] sm:w-[400px] sm:h-[400px] lg:w-[600px] lg:h-[600px] xl:w-[720px] xl:h-[720px]
             bg-brand-magenta/[0.07] rounded-full
             blur-[80px] sm:blur-[100px] lg:blur-[120px] xl:blur-[140px]"
    >
    </div>
    <!-- Shape A: top-right corner accent — tucked into the corner, clear of the mark -->
    <div
      class="hero-shape-a absolute -top-[25%] -right-[22%] sm:-top-[35%] sm:-right-[28%] xl:-top-[32%] xl:-right-[22%]
             w-[280px] h-[280px] sm:w-[400px] sm:h-[400px] lg:w-[550px] lg:h-[550px] xl:w-[640px] xl:h-[640px]
             bg-white/[0.03] sm:bg-white/[0.035] xl:bg-white/[0.045] rotate-45 rounded-2xl sm:rounded-3xl"
    >
    </div>
    <!-- Shape B: bottom-left diagonal — hidden on mobile, adds depth on larger screens -->
    <div
      class="hero-shape-b hidden sm:block
             absolute -bottom-1/3 -left-[10%]
             sm:w-[340px] sm:h-[340px] lg:w-[500px] lg:h-[500px] xl:w-[580px] xl:h-[580px]
             bg-white/[0.02] lg:bg-white/[0.025] xl:bg-white/[0.035] -rotate-12 rounded-3xl"
    >
    </div>
  </div>

  <!-- Brand mark — lower-right on mobile, vertically centred right on desktop -->
  <div
    class="absolute inset-0 z-10 flex items-end sm:items-center justify-end pointer-events-none select-none"
    aria-hidden="true"
  >
    <img
      src="/images/brand/nios-fearr-logo-mark-purple.png"
      alt=""
      class="hero-mark w-[220px] sm:w-[380px] lg:w-[460px] xl:w-[520px] 2xl:w-[600px] mr-[2%] mb-[8%] sm:mb-0 sm:mr-[6%] lg:mr-[8%] opacity-0 brightness-0 invert"
    />
  </div>

  <!-- Content -->
  <div class="relative mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8 py-32 lg:py-40">
    <div class="max-w-2xl lg:max-w-3xl">
      <!-- Accent bar -->
      <div
        class="w-10 h-1 bg-brand-magenta rounded-full mb-8 animate-fade-in"
      >
      </div>

      <h1
        class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white leading-[1.08] tracking-tight animate-fade-in-up"
      >
        Igniting Your<br />
        <span class="text-brand-magenta inline-block mt-1 sm:mt-2">Ambition</span>
      </h1>

      <p
        class="mt-8 text-lg sm:text-xl text-white/70 leading-[1.7] max-w-lg animate-fade-in-up"
        style="animation-delay: 0.15s;"
      >
        Strategic technology consultancy and developmental mentoring for
        organisations navigating digital change. Over 20 years of proven
        expertise across Ireland and beyond.
      </p>

      <div
        class="mt-12 flex flex-wrap gap-4 animate-fade-in-up"
        style="animation-delay: 0.3s;"
      >
        <a
          href="#contact"
          class="group relative bg-brand-magenta text-white px-8 py-3.5 rounded-full font-semibold text-lg transition-all duration-200 hover:shadow-[0_4px_24px_rgba(233,30,123,0.4)] hover:-translate-y-0.5 active:translate-y-0"
        >
          Get in Touch
        </a>
        <a
          href="#services"
          class="border border-white/20 text-white px-8 py-3.5 rounded-full font-semibold text-lg transition-all duration-200 hover:border-white/50 hover:bg-white/[0.06] hover:-translate-y-0.5 active:translate-y-0"
        >
          Our Services
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom curve -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg
      viewBox="0 0 1440 60"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-auto"
      preserveAspectRatio="none"
    >
      <path
        d="M0 60L1440 60L1440 0C1200 50 240 50 0 0L0 60Z"
        fill="#F5F5F5"></path>
    </svg>
  </div>
</section>

<script>
  function initHeroMark() {
    const mark = document.querySelector(".hero-mark") as HTMLElement | null;
    if (!mark) return;

    // Soft reveal on load — slightly more present on large screens
    const targetOpacity = window.innerWidth >= 1280 ? "0.18" : "0.12";
    requestAnimationFrame(() => {
      mark.style.transition =
        "opacity 1.2s ease-out, transform 1.2s ease-out";
      mark.style.transform = "translateY(0)";
      mark.style.opacity = targetOpacity;
    });

    // Gentle parallax drift on scroll
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY * 0.08;
        mark!.style.transform = `translateY(${-y}px)`;
        ticking = false;
      });
    }
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  document.addEventListener("astro:page-load", initHeroMark);
</script>

<style>
  /* Ambient geometry motion — xl+ only, uses individual transform properties
     (translate / scale) so they compose with Tailwind's rotate without conflict */
  @media (min-width: 1280px) {
    .hero-shape-a { animation: hero-drift-a 18s ease-in-out infinite; }
    .hero-shape-b { animation: hero-drift-b 22s ease-in-out infinite; }
    .hero-glow    { animation: hero-glow-breathe 12s ease-in-out infinite; }
  }

  @keyframes hero-drift-a {
    0%, 100% { translate: 0 0; }
    50%      { translate: 12px -14px; }
  }

  @keyframes hero-drift-b {
    0%, 100% { translate: 0 0; }
    50%      { translate: -10px 12px; }
  }

  @keyframes hero-glow-breathe {
    0%, 100% { scale: 1; }
    50%      { scale: 1.07; }
  }
</style>
