---

<section
  class="relative flex items-center justify-center bg-brand-purple overflow-hidden"
  style="min-height: 65vh;"
>
  <!-- Background layers — viewport-corner positioning -->
  <div class="absolute inset-0" aria-hidden="true">
    <!-- Centered soft halo behind headline -->
    <div
      class="hero-glow absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
             w-[280px] h-[280px] sm:w-[380px] sm:h-[380px] lg:w-[480px] lg:h-[480px]
             bg-brand-magenta/[0.04] sm:bg-brand-magenta/[0.045] lg:bg-brand-magenta/[0.05]
             rounded-full
             blur-[90px] sm:blur-[110px] lg:blur-[130px]"
    >
    </div>

    <!-- Shape: top-left corner (white) — mirrored balance -->
    <div
      class="hero-shape-tl absolute -top-[20%] -left-[15%] sm:-top-[25%] sm:-left-[18%] lg:-top-[30%] lg:-left-[15%]
             w-[240px] h-[240px] sm:w-[340px] sm:h-[340px] lg:w-[450px] lg:h-[450px] xl:w-[520px] xl:h-[520px]
             bg-white/[0.018] sm:bg-white/[0.022] lg:bg-white/[0.025]
             -rotate-45 rounded-2xl sm:rounded-3xl
             opacity-0"
      style="animation: hero-shape-enter-tl 1.2s ease-out 0.5s both;"
    >
    </div>

    <!-- Shape: top-right corner (white) — tucked into corner -->
    <div
      class="hero-shape-tr absolute -top-[20%] -right-[15%] sm:-top-[25%] sm:-right-[18%] lg:-top-[30%] lg:-right-[15%]
             w-[240px] h-[240px] sm:w-[340px] sm:h-[340px] lg:w-[450px] lg:h-[450px] xl:w-[520px] xl:h-[520px]
             bg-white/[0.018] sm:bg-white/[0.022] lg:bg-white/[0.025]
             rotate-45 rounded-2xl sm:rounded-3xl
             opacity-0"
      style="animation: hero-shape-enter-tr 1.2s ease-out 0.6s both;"
    >
    </div>

    <!-- Shape: bottom-left corner (magenta tint) — hidden on mobile -->
    <div
      class="hero-shape-bl hidden sm:block absolute -bottom-[25%] -left-[12%] lg:-bottom-[30%] lg:-left-[10%]
             sm:w-[280px] sm:h-[280px] lg:w-[380px] lg:h-[380px] xl:w-[440px] xl:h-[440px]
             bg-brand-magenta/[0.02] lg:bg-brand-magenta/[0.025]
             -rotate-12 rounded-3xl
             opacity-0"
      style="animation: hero-shape-enter-bl 1.2s ease-out 0.7s both;"
    >
    </div>
  </div>

  <!-- Content — centered -->
  <div class="relative mx-auto max-w-4xl w-full px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24 text-center">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black text-white leading-[1.1] tracking-tight animate-fade-in-up"
      style="font-family: var(--font-display);"
    >
      Igniting Your
      <span class="hero-typing-wrapper block mt-1 sm:mt-2">
        <span class="hero-typing-container text-brand-magenta" aria-label="Ambition">
          <span class="hero-typing-text"></span><span class="hero-cursor">|</span>
        </span>
        <span class="hero-underline block mx-auto w-0 h-1 bg-brand-magenta rounded-full mt-2 sm:mt-3 max-w-[200px] sm:max-w-[260px] lg:max-w-[320px]"></span>
      </span>
    </h1>

    <p
      class="mt-6 sm:mt-8 text-lg sm:text-xl text-white/60 leading-relaxed max-w-xl mx-auto font-light animate-fade-in-up"
      style="animation-delay: 0.15s;"
    >
      Strategic technology consultancy and developmental mentoring for
      organisations navigating digital change. Over 20 years of proven
      expertise across Ireland and beyond.
    </p>

    <div
      class="mt-8 sm:mt-10 flex flex-wrap justify-center gap-4 animate-fade-in-up"
      style="animation-delay: 0.3s;"
    >
      <a
        href="#contact"
        class="bg-brand-magenta text-white px-8 py-3.5 rounded-full font-semibold text-lg transition-all duration-200 hover:shadow-[0_4px_24px_rgba(233,30,123,0.4)] hover:-translate-y-0.5 active:translate-y-0"
      >
        Get in Touch
      </a>
      <a
        href="#services"
        class="border border-white/20 text-white px-8 py-3.5 rounded-full font-semibold text-lg transition-all duration-200 hover:border-white/50 hover:bg-white/[0.06] hover:-translate-y-0.5 active:translate-y-0"
      >
        Our Services
      </a>
    </div>
  </div>

  <!-- Bottom curve -->
  <div class="absolute -bottom-[1px] left-0 right-0">
    <svg
      viewBox="0 0 1440 60"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-auto block"
      preserveAspectRatio="none"
    >
      <path
        d="M0 60L1440 60L1440 0C1200 50 240 50 0 0L0 60Z"
        fill="#F5F5F5"></path>
    </svg>
  </div>
</section>

<script>
  // Hero typing animation
  document.addEventListener("astro:page-load", () => {
    const wrapperEl = document.querySelector('.hero-typing-wrapper') as HTMLElement;
    const textEl = document.querySelector('.hero-typing-text') as HTMLElement;
    const cursorEl = document.querySelector('.hero-cursor') as HTMLElement;
    const underlineEl = document.querySelector('.hero-underline') as HTMLElement;
    if (!textEl || !wrapperEl) return;

    const words = ['Clarity', 'Confidence', 'Ambition'];
    const typeSpeed = 80;
    const deleteSpeed = 50;
    const pauseAfterWord = 300;
    const pauseBeforeDelete = 200;

    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    const type = () => {
      const currentWord = words[wordIndex];
      const isFinalWord = wordIndex === words.length - 1;

      if (!isDeleting) {
        // Typing
        textEl.textContent = currentWord.substring(0, charIndex + 1);
        charIndex++;

        if (charIndex === currentWord.length) {
          // Word complete
          if (isFinalWord) {
            // Final word - hide cursor and show underline after a brief pause
            setTimeout(() => {
              if (cursorEl) cursorEl.style.display = 'none';
              if (underlineEl) {
                underlineEl.style.width = '100%';
              }
            }, 300);
            return;
          }
          // Pause then delete
          setTimeout(() => {
            isDeleting = true;
            type();
          }, pauseBeforeDelete);
          return;
        }
      } else {
        // Deleting
        textEl.textContent = currentWord.substring(0, charIndex - 1);
        charIndex--;

        if (charIndex === 0) {
          // Move to next word
          isDeleting = false;
          wordIndex++;
          setTimeout(type, pauseAfterWord);
          return;
        }
      }

      setTimeout(type, isDeleting ? deleteSpeed : typeSpeed);
    };

    // Start animation after initial delay
    setTimeout(type, 700);
  });
</script>

<style>
  /* Hero typing animation — stable wrapper structure */
  .hero-typing-wrapper {
    display: block;
    text-align: center;
  }

  .hero-typing-container {
    display: block;
    min-height: 1.15em;
  }

  .hero-typing-text {
    display: inline;
  }

  .hero-underline {
    transition: width 1s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: width;
  }

  .hero-cursor {
    display: inline;
    font-weight: 300;
    margin-left: 1px;
    animation: hero-cursor-blink 0.7s ease-in-out infinite;
  }

  @keyframes hero-cursor-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  /* Shape entrance animations — one-time on page load */
  @keyframes hero-shape-enter-tl {
    0% {
      opacity: 0;
      translate: -15px -15px;
    }
    100% {
      opacity: 1;
      translate: 0 0;
    }
  }

  @keyframes hero-shape-enter-tr {
    0% {
      opacity: 0;
      translate: 15px -15px;
    }
    100% {
      opacity: 1;
      translate: 0 0;
    }
  }

  @keyframes hero-shape-enter-bl {
    0% {
      opacity: 0;
      translate: -15px 15px;
    }
    100% {
      opacity: 1;
      translate: 0 0;
    }
  }

  /* Ambient geometry motion — xl+ only */
  @media (min-width: 1280px) {
    .hero-glow { animation: hero-glow-breathe 12s ease-in-out infinite; }
    .hero-shape-tl { animation: hero-drift-tl 18s ease-in-out infinite; }
    .hero-shape-tr { animation: hero-drift-tr 18s ease-in-out infinite; }
    .hero-shape-bl { animation: hero-drift-bl 22s ease-in-out infinite; }
  }

  @keyframes hero-glow-breathe {
    0%, 100% { scale: 1; }
    50%      { scale: 1.06; }
  }

  @keyframes hero-drift-tl {
    0%, 100% { translate: 0 0; }
    50%      { translate: -10px -12px; }
  }

  @keyframes hero-drift-tr {
    0%, 100% { translate: 0 0; }
    50%      { translate: 10px -12px; }
  }

  @keyframes hero-drift-bl {
    0%, 100% { translate: 0 0; }
    50%      { translate: -8px 10px; }
  }
</style>
