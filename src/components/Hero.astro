---

---

<section class="relative min-h-screen flex items-center bg-brand-purple overflow-hidden">
  <!-- Geometric background elements (brochure-inspired diagonals) -->
  <div class="absolute inset-0" aria-hidden="true">
    <div
      class="absolute -top-1/4 -right-1/4 w-[600px] h-[600px] bg-brand-magenta/8 rotate-45 rounded-3xl"
    >
    </div>
    <div
      class="absolute -bottom-1/4 -left-1/6 w-[500px] h-[500px] bg-white/5 -rotate-12 rounded-3xl"
    >
    </div>
    <div
      class="absolute top-1/3 right-1/4 w-[300px] h-[300px] bg-brand-magenta/5 rotate-12 rounded-full"
    >
    </div>
    <!-- Diagonal line accent -->
    <div
      class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-brand-purple via-brand-purple to-brand-purple-light opacity-80"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-32">
    <div class="max-w-3xl">
      <!-- Subtle accent line -->
      <div class="w-12 h-1 bg-brand-magenta rounded-full mb-8 animate-fade-in">
      </div>

      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight animate-fade-in-up"
      >
        Igniting Your
        <span class="text-brand-magenta">Ambition</span>
      </h1>

      <p
        class="mt-6 text-lg sm:text-xl text-white/80 leading-relaxed max-w-2xl animate-fade-in-up"
        style="animation-delay: 0.15s;"
      >
        Strategic technology consultancy and developmental mentoring for
        organisations navigating digital change. Over 20 years of proven
        expertise across Ireland and beyond.
      </p>

      <div
        class="mt-10 flex flex-wrap gap-4 animate-fade-in-up"
        style="animation-delay: 0.3s;"
      >
        <a
          href="#contact"
          class="bg-brand-magenta text-white px-8 py-3.5 rounded-full font-semibold hover:bg-brand-magenta-hover transition-colors text-lg"
        >
          Get in Touch
        </a>
        <a
          href="#services"
          class="border border-white/30 text-white px-8 py-3.5 rounded-full font-semibold hover:bg-white/10 transition-colors text-lg"
        >
          Our Services
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom curve transition -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg
      viewBox="0 0 1440 60"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full h-auto"
      preserveAspectRatio="none"
    >
      <path d="M0 60L1440 60L1440 0C1200 50 240 50 0 0L0 60Z" fill="#F5F5F5"
      ></path>
    </svg>
  </div>
</section>
